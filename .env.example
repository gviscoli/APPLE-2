AWS_ACCESS_KEY_ID=<your_aws_access_key_id>
AWS_SECRET_ACCESS_KEY=<your_aws_secret_access_key>
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=eu-central-1

# ─── Ollama Models ────────────────────────────────────────────────────────
# LLM_MODEL_LOCAL: scegli tra llama3.2, mistral, gemma2, phi3, ...
# LLM_MODEL_CLOUD: scegli tra quelli disponibili su Amazon Bedrock (amazon.nova-lite-v1:0...)
#
LLM_MODEL_LOCAL=llama3.2
LLM_MODEL_CLOUD=amazon.nova-lite-v1:0

# "local" o "cloud"
#
INFERENCE_MODE = "cloud"  