AWS_ACCESS_KEY_ID=<your_aws_access_key_id>
AWS_SECRET_ACCESS_KEY=<your_aws_secret_access_key>
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=eu-central-1

# ─── Modalità di inferenza ────────────────────────────────────────────────────
# Valori possibili:
#   cloud      → Amazon Nova via AWS Bedrock  (LLM_MODEL_CLOUD)
#   anthropic  → Claude via AWS Bedrock       (LLM_MODEL_ANTHROPIC)
#   ollama     → modello locale via Ollama    (LLM_MODEL_OLLAMA)
#   local      → alias legacy per Ollama      (LLM_MODEL_LOCAL)
#
INFERENCE_MODE=cloud

# ─── Amazon Nova (Bedrock) ────────────────────────────────────────────────────
# Usato quando INFERENCE_MODE=cloud
# Modelli disponibili: amazon.nova-lite-v1:0 | amazon.nova-pro-v1:0
#
LLM_MODEL_CLOUD=amazon.nova-lite-v1:0

# ─── Anthropic Claude (Bedrock) ───────────────────────────────────────────────
# Usato quando INFERENCE_MODE=anthropic
# Il modello deve essere abilitato nella tua region AWS (richiede model access su Bedrock)
# Modelli disponibili:
#   anthropic.claude-3-haiku-20240307-v1:0     (veloce, economico)
#   anthropic.claude-3-5-sonnet-20241022-v2:0  (bilanciato)
#   anthropic.claude-3-opus-20240229-v1:0      (piu' capace)
#
LLM_MODEL_ANTHROPIC=anthropic.claude-3-haiku-20240307-v1:0

# ─── Ollama locale ────────────────────────────────────────────────────────────
# Usato quando INFERENCE_MODE=ollama (o local)
# Avvia Ollama prima di lanciare il proxy:
#   ollama serve
#   ollama pull llama4
# Modelli alternativi: llama4:scout | llama4:maverick | llama3.2 | mistral
#
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL_OLLAMA=llama4
LLM_MODEL_LOCAL=llama3.2
